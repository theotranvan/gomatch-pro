# GoMatch Backend — Railway Environment Variables
# Set these in the Railway dashboard under your service's Variables tab.

# Django
DJANGO_SECRET_KEY=your-production-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app.railway.app

# Database (auto-injected by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:port/dbname

# CORS — allow your Expo app origin (use * for dev builds)
CORS_ALLOWED_ORIGINS=*

# Port (auto-injected by Railway)
PORT=8000
